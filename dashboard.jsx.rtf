      border: accent ? "1px solid #1e3a5f" : "1px solid #1a2230",\
      borderRadius: 10,\
      padding: size === "large" ? "20px 22px" : "16px 18px",\
      display: "flex",\
      flexDirection: "column",\
      gap: 6,\
      transition: "border-color 0.2s",\
    \}\}>\
      <span style=\{\{ color: "#6b7a8d", fontSize: 11, fontWeight: 600, textTransform: "uppercase", letterSpacing: 1.1 \}\}>\{label\}</span>\
      <span style=\{\{ color: accent ? "#60a5fa" : "#e8ecf1", fontSize: size === "large" ? 28 : 22, fontWeight: 700, letterSpacing: -0.5 \}\}>\
        \{format === "currency" ? formatCurrency(current, true) : current.toLocaleString()\}\{suffix\}\
      </span>\
      \{prior !== undefined && <Delta current=\{current\} prior=\{priorVal\} suffix=\{suffix\} invert=\{invert\} format=\{format\} />\}\
