              <MetricCard label="Weekly Collections" value=\{FINANCIAL.weeklyCollections\} prior=\{FINANCIAL.weeklyCollectionsPrior\} format="currency" size="large" />\
              <MetricCard label="Weekly Cash Burn" value=\{FINANCIAL.weeklyCashBurn\} prior=\{FINANCIAL.weeklyCashBurnPrior\} format="currency" invert size="large" />\
              <CashRunwayGauge />\
            </div>\
\
            <SectionHeader icon="\uc0\u9672 " title="Profitability Metrics" subtitle="Margin and cost structure" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <MetricCard label="Gross Margin" value=\{FINANCIAL.grossMarginPct\} prior=\{FINANCIAL.grossMarginPctPrior\} suffix="%" size="large" />\
              <MetricCard label="Payroll % of Revenue" value=\{FINANCIAL.payrollPctRevenue\} prior=\{FINANCIAL.payrollPctRevenuePrior\} suffix="%" invert size="large" />\
              <MetricCard label="EBITDA (Trailing 4wk)" value=\{FINANCIAL.ebitdaTrailing\} prior=\{FINANCIAL.ebitdaTrailingPrior\} format="currency" size="large" />\
              <MetricCard label="DSO" value=\{FINANCIAL.dso\} prior=\{FINANCIAL.dsoPrior\} suffix=" days" invert size="large" />\
            </div>\
\
            <SectionHeader icon="\uc0\u9673 " title="Accounts Receivable & Payable" subtitle="Aging analysis" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 28 \}\}>\
              <AgingTable data=\{FINANCIAL.arAging\} label="AR Aging \'97 Outstanding" />\
              <AgingTable data=\{FINANCIAL.apAging\} label="AP Aging \'97 Outstanding" />\
            </div>\
\
            \{/* 60+ day callout */\}\
            <div style=\{\{\
              background: "linear-gradient(135deg, #2d1215 0%, #1a0a0c 100%)",\
              border: "1px solid #5c2020",\
              borderRadius: 10,\
              padding: "18px 22px",\
              display: "flex",\
              justifyContent: "space-between",\
              alignItems: "center",\
            \}\}>\
              <div>\
                <div style=\{\{ color: "#fca5a5", fontSize: 12, fontWeight: 700, textTransform: "uppercase", letterSpacing: 1 \}\}>\uc0\u9888  AR 60+ Days Outstanding</div>\
                <div style=\{\{ color: "#8a8f98", fontSize: 12, marginTop: 4 \}\}>\
                  \{formatCurrency(FINANCIAL.arAging.sixty + FINANCIAL.arAging.ninety)\} in receivables aged beyond 60 days \'97 \{((FINANCIAL.arAging.sixty + FINANCIAL.arAging.ninety) / FINANCIAL.arAging.total * 100).toFixed(1)\}% of total AR\
                </div>\
              </div>\
              <div style=\{\{ color: "#ef4444", fontSize: 28, fontWeight: 800 \}\}>\{formatCurrency(FINANCIAL.arAging.sixty + FINANCIAL.arAging.ninety, true)\}</div>\
            </div>\
          </div>\
        )\}\
\
        \{/* ========= OPERATIONS TAB ========= */\}\
        \{activeTab === "operations" && (\
          <div>\
            <SectionHeader icon="\uc0\u9889 " title="Service Delivery" subtitle="Ticket metrics and SLA performance" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <TicketFlowBar />\
              <MetricCard label="Open Tickets" value=\{SERVICE.openTickets\} prior=\{SERVICE.openTicketsPrior\} invert size="large" />\
              <MetricCard label="SLA Compliance" value=\{SERVICE.slaCompliancePct\} prior=\{SERVICE.slaCompliancePctPrior\} suffix="%" size="large" />\
              <MetricCard label="Avg Resolution Time" value=\{SERVICE.avgResolutionHrs\} prior=\{SERVICE.avgResolutionHrsPrior\} suffix=" hrs" invert />\
              <MetricCard label="Escalations" value=\{SERVICE.escalations\} prior=\{SERVICE.escalationsPrior\} invert />\
              <MetricCard label="Aged 7+ Days" value=\{SERVICE.agedTickets7Plus\} prior=\{SERVICE.agedTickets7PlusPrior\} invert />\
            </div>\
\
            <SectionHeader icon="\uc0\u9673 " title="Utilization" subtitle="Team capacity and efficiency" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <MetricCard label="Service Team" value=\{UTILIZATION.serviceUtil\} prior=\{UTILIZATION.serviceUtilPrior\} suffix="%" accent />\
              <MetricCard label="Project Team" value=\{UTILIZATION.projectUtil\} prior=\{UTILIZATION.projectUtilPrior\} suffix="%" />\
              <MetricCard label="Company-Wide" value=\{UTILIZATION.companyUtil\} prior=\{UTILIZATION.companyUtilPrior\} suffix="%" />\
              <MetricCard label="Overtime Hours" value=\{UTILIZATION.overtimeHours\} prior=\{UTILIZATION.overtimeHoursPrior\} invert />\
            </div>\
\
            <div style=\{\{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 28 \}\}>\
              <div>\
                <SectionHeader icon="\uc0\u9632 " title="Project Delivery" />\
                <ProjectStatusBar />\
                <div style=\{\{ marginTop: 12 \}\}>\
                  <MetricCard label="Hours Budget Consumed" value=\{PROJECTS.hoursConsumedPct\} prior=\{PROJECTS.hoursConsumedPctPrior\} suffix="%" invert />\
                </div>\
              </div>\
              <div>\
                <SectionHeader icon="\uc0\u9960 " title="Security Posture" />\
                <div style=\{\{ display: "flex", flexDirection: "column", gap: 12 \}\}>\
                  <MetricCard label="Critical Alerts Open" value=\{SECURITY.criticalAlerts\} prior=\{SECURITY.criticalAlertsPrior\} invert size="large" />\
                  <div style=\{\{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 \}\}>\
                    <MetricCard label="Incidents Opened" value=\{SECURITY.incidentsOpened\} />\
                    <MetricCard label="Incidents Resolved" value=\{SECURITY.incidentsResolved\} />\
                  </div>\
                  <MetricCard label="Overdue Patching" value=\{SECURITY.overduePatching\} prior=\{SECURITY.overduePatchingPrior\} invert />\
                </div>\
              </div>\
            </div>\
\
            <SectionHeader icon="\uc0\u9829 " title="Client Health" subtitle="Satisfaction and renewal pipeline" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12 \}\}>\
              <MetricCard label="CSAT Score" value=\{CLIENT_HEALTH.csatScore\} prior=\{CLIENT_HEALTH.csatScorePrior\} suffix="/5" />\
              <MetricCard label="Escalated Clients" value=\{CLIENT_HEALTH.clientsWithEscalations\} prior=\{CLIENT_HEALTH.clientsWithEscalationsPrior\} invert />\
              <MetricCard label="Spike Alerts" value=\{CLIENT_HEALTH.spikeAlerts\} />\
              <div style=\{\{ background: "#111820", border: "1px solid #1a2230", borderRadius: 10, padding: "16px 18px" \}\}>\
                <span style=\{\{ color: "#6b7a8d", fontSize: 11, fontWeight: 600, textTransform: "uppercase", letterSpacing: 1.1 \}\}>Renewals Due</span>\
                <div style=\{\{ display: "flex", gap: 14, marginTop: 10 \}\}>\
                  \{[\
                    \{ d: "30d", v: CLIENT_HEALTH.renewalsNext30, c: "#ef4444" \},\
                    \{ d: "60d", v: CLIENT_HEALTH.renewalsNext60, c: "#eab308" \},\
                    \{ d: "90d", v: CLIENT_HEALTH.renewalsNext90, c: "#22c55e" \},\
                  ].map((r) => (\
                    <div key=\{r.d\} style=\{\{ textAlign: "center" \}\}>\
                      <div style=\{\{ color: r.c, fontSize: 18, fontWeight: 800 \}\}>\{r.v\}</div>\
                      <div style=\{\{ color: "#4a5568", fontSize: 10 \}\}>\{r.d\}</div>\
                    </div>\
                  ))\}\
                </div>\
              </div>\
            </div>\
          </div>\
        )\}\
\
        \{/* ========= SALES TAB ========= */\}\
        \{activeTab === "sales" && (\
          <div>\
            <SectionHeader icon="\uc0\u9672 " title="Revenue" subtitle="MRR movement and growth" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <MetricCard label="Net MRR Movement" value=\{REVENUE.netMRRMovement\} prior=\{REVENUE.netMRRMovementPrior\} format="currency" accent size="large" />\
              <MetricCard label="New MRR Sold" value=\{REVENUE.newMRRSold\} prior=\{REVENUE.newMRRSoldPrior\} format="currency" size="large" />\
              <MetricCard label="MRR Churned" value=\{REVENUE.mrrChurned\} prior=\{REVENUE.mrrChurnedPrior\} format="currency" invert size="large" />\
              <MetricCard label="Total MRR" value=\{REVENUE.totalMRR\} format="currency" accent size="large" />\
            </div>\
\
            <SectionHeader icon="\uc0\u9671 " title="Pipeline & Activity" subtitle="Funnel health and conversion" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <MetricCard label="Pipeline Value" value=\{REVENUE.pipelineValue\} prior=\{REVENUE.pipelineValuePrior\} format="currency" size="large" />\
              <MetricCard label="Proposals Sent" value=\{REVENUE.proposalsSent\} prior=\{REVENUE.proposalsSentPrior\} size="large" />\
              <MetricCard label="Win Rate" value=\{SALES.winRate\} prior=\{SALES.winRatePrior\} suffix="%" size="large" />\
              <MetricCard label="New Opps Created" value=\{SALES.newOppsCreated\} prior=\{SALES.newOppsCreatedPrior\} size="large" />\
            </div>\
\
            <SectionHeader icon="\uc0\u9889 " title="BDR & Outbound Activity" subtitle="Top-of-funnel generation" />\
            <div style=\{\{ display: "grid", gridTemplateColumns: "repeat(3, 1fr)", gap: 12, marginBottom: 28 \}\}>\
              <MetricCard label="Outbound Activities" value=\{SALES.outboundActivities\} prior=\{SALES.outboundActivitiesPrior\} size="large" />\
              <MetricCard label="Meetings Booked" value=\{SALES.meetingsBooked\} prior=\{SALES.meetingsBookedPrior\} size="large" />\
              <MetricCard label="Meetings Held" value=\{SALES.meetingsHeld\} prior=\{SALES.meetingsHeldPrior\} size="large" />\
            </div>\
\
            \{/* Conversion funnel visual */\}\
            <div style=\{\{\
              background: "#111820",\
              border: "1px solid #1a2230",\
              borderRadius: 10,\
              padding: "20px 24px",\
            \}\}>\
              <span style=\{\{ color: "#6b7a8d", fontSize: 11, fontWeight: 600, textTransform: "uppercase", letterSpacing: 1.1 \}\}>Weekly Conversion Funnel</span>\
              <div style=\{\{ display: "flex", alignItems: "center", gap: 0, marginTop: 16 \}\}>\
                \{[\
                  \{ label: "Outbound", val: SALES.outboundActivities, color: "#1e3a5f" \},\
                  \{ label: "Booked", val: SALES.meetingsBooked, color: "#1e4a3f" \},\
                  \{ label: "Held", val: SALES.meetingsHeld, color: "#1e5a2f" \},\
                  \{ label: "Opps", val: SALES.newOppsCreated, color: "#2e6a1f" \},\
                  \{ label: "Proposals", val: REVENUE.proposalsSent, color: "#3e7a0f" \},\
                ].map((step, i, arr) => (\
                  <div key=\{step.label\} style=\{\{ flex: 1, display: "flex", flexDirection: "column", alignItems: "center" \}\}>\
                    <div style=\{\{\
                      background: step.color,\
                      borderRadius: 8,\
                      padding: "14px 8px",\
                      width: `$\{100 - (i * 12)\}%`,\
                      textAlign: "center",\
                      position: "relative",\
                    \}\}>\
                      <div style=\{\{ color: "#e8ecf1", fontSize: 20, fontWeight: 800 \}\}>\{step.val\}</div>\
                      <div style=\{\{ color: "#8a8f98", fontSize: 10, fontWeight: 600, marginTop: 2 \}\}>\{step.label\}</div>\
                    </div>\
                    \{i < arr.length - 1 && (\
                      <div style=\{\{ color: "#4a5568", fontSize: 10, margin: "4px 0", fontFamily: "'JetBrains Mono', monospace" \}\}>\
                        \{((arr[i + 1].val / step.val) * 100).toFixed(0)\}%\uc0\u8594 \
                      </div>\
                    )\}\
                  </div>\
                ))\}\
              </div>\
            </div>\
          </div>\
        )\}\
\
        \{/* FOOTER */\}\
        <div style=\{\{\
          marginTop: 36,\
          paddingTop: 16,\
          borderTop: "1px solid #1a2230",\
          display: "flex",\
          justifyContent: "space-between",\
          color: "#3a4250",\
          fontSize: 10,\
        \}\}>\
          <span>DataPath Executive Dashboard \'97 Confidential</span>\
          <span>All data is placeholder \'97 connect your live sources to populate</span>\
          <span>Generated \{new Date().toLocaleDateString()\}</span>\
        </div>\
      </div>\
    </div>\
  );\
\}}