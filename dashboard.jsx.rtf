function formatCurrency(val, compact = false) \{\
  if (compact && Math.abs(val) >= 1000000) \{\
    return "$" + (val / 1000000).toFixed(1) + "M";\
  \}\
  if (compact && Math.abs(val) >= 1000) \{\
    return "$" + (val / 1000).toFixed(0) + "K";\
  \}\
  return val < 0\
    ? "-$" + Math.abs(val).toLocaleString()\
    : "$" + val.toLocaleString();\
\}\
\
function Delta(\{ current, prior, suffix = "", invert = false, format = "number" \}) \{\
  const diff = current - prior;\
  const isPositive = invert ? diff < 0 : diff > 0;\
  const isNeutral = diff === 0;\
  const color = isNeutral ? "#8a8f98" : isPositive ? "#22c55e" : "#ef4444";\
  const arrow = isNeutral ? "\'96" : isPositive ? "\uc0\u9650 " : "\u9660 ";\
  let displayDiff = Math.abs(diff);\
  if (format === "currency") displayDiff = formatCurrency(Math.abs(diff), true);\
  else if (format === "pct") displayDiff = Math.abs(diff).toFixed(1) + "%";\
  else displayDiff = Math.abs(diff).toLocaleString();\
\
  return (\
    <span style=\{\{ color, fontSize: 11, fontWeight: 600, letterSpacing: 0.3 \}\}>\
      \{arrow\} \{displayDiff\}\{suffix\} vs prior wk\
    </span>\
  );\
\}\
